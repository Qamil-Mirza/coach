{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@coach/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@coach/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@coach/db": [
        "../../packages/db/src/index.ts"
      ],
      "@coach/db/*": [
        "../../packages/db/src/*"
      ],
      "@coach/integrations": [
        "../../packages/integrations/src/index.ts"
      ],
      "@coach/integrations/*": [
        "../../packages/integrations/src/*"
      ],
      "@coach/ai": [
        "../../packages/ai/src/index.ts"
      ],
      "@coach/ai/*": [
        "../../packages/ai/src/*"
      ],
      "@coach/observability": [
        "../../packages/observability/src/index.ts"
      ],
      "@coach/observability/*": [
        "../../packages/observability/src/*"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true,
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
